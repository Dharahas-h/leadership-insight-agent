{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"python.defaultInterpreterPath": "c:/Users/DharahasHanumanthu/Personal/Insights/backend/.venv/Scripts/python.exe",
		"[python]": {
			"editor.defaultFormatter": "charliermarsh.ruff",
			"editor.formatOnSave": true,
			"editor.codeActionsOnSave": {
				"source.fixAll": "explicit",
				"source.organizeImports": "explicit"
			}
		},
		"ruff.lint.enable": true,
		"ruff.interpreter": [
			"c:/Users/DharahasHanumanthu/Personal/Insights/backend/.venv/Scripts/python.exe"
		],
		"files.exclude": {
			"**/__pycache__": true,
			"**/*.pyc": true,
			"**/.ruff_cache": true
		},
		"files.watcherExclude": {
			"**/.git/objects/**": true,
			"**/.git/subtree-cache/**": true,
			"**/node_modules/**": true,
			"**/.venv/**": true,
			"**/__pycache__/**": true
		},
		"python.analysis.autoImportCompletions": true,
		"python.terminal.activateEnvironment": true,
		"inlineChat.defaultModel": "claude-sonnet-4-5 (Added, Supports Agent Mode) (aitk-foundry)"
	},
	"extensions": {
		"recommendations": [
			"charliermarsh.ruff",
			"ms-python.python",
			"ms-python.vscode-pylance"
		]
	},
	"launch": {
		"version": "0.2.0",
		"configurations": [
			{
				"name": "Python: Current File",
				"type": "debugpy",
				"request": "launch",
				"program": "${file}",
				"console": "integratedTerminal",
				"justMyCode": true
			},
			{
				"name": "Python: Main",
				"type": "debugpy",
				"request": "launch",
				"program": "${workspaceFolder}/main.py",
				"console": "integratedTerminal",
				"justMyCode": true
			}
		]
	}
}